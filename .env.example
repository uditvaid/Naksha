# Nakshatra — Environment Variables
# Copy to .env and fill in your values

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# RevenueCat (get from app.revenuecat.com)
REVENUECAT_API_KEY_IOS=appl_YOUR_KEY_HERE
REVENUECAT_API_KEY_ANDROID=goog_YOUR_KEY_HERE

# EAS Project (get from expo.dev)
EAS_PROJECT_ID=YOUR_EAS_PROJECT_ID

# Apple (for App Store submission)
APPLE_ID=your@email.com
APPLE_TEAM_ID=YOUR_TEAM_ID
ASC_APP_ID=YOUR_APP_STORE_CONNECT_APP_ID

# Optional: Jyotish API for precise ephemeris calculations
# Recommended: prokerala.com API or astro-seek API
JYOTISH_API_KEY=YOUR_JYOTISH_API_KEY
JYOTISH_API_URL=https://api.prokerala.com/v2/astrology
